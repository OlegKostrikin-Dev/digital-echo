# =====================================================
# MySQL — корпоративная БД ЭСФ-документов (заголовки + строки)
# =====================================================
# Если MySQL запущен на хосте macOS/Windows, используйте host.docker.internal
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_USER=your_user
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=your_database

# =====================================================
# MySQL — демо-БД с синтетическими ЭСФ (отдельная database)
# =====================================================
# Генератор: cd services/backend && PYTHONPATH=src python -m core.synthetic_esf --truncate --count 300000
# (по умолчанию ~8% документов — демо-кейсы ①–②; см. --demo-archetype-pct / --nr-spillover)
# Пересчёт API: MYSQL_USE_SYNTHETIC=1; окно дат — ESF_SYNTHETIC_WINDOW (rolling | calendar)
# Локально: 127.0.0.1. Из контейнера на Mac: host.docker.internal. Иначе — IP сервера (как в DBeaver).
MYSQL_SYNTHETIC_HOST=127.0.0.1
MYSQL_SYNTHETIC_PORT=3306
MYSQL_SYNTHETIC_USER=esf_synth
MYSQL_SYNTHETIC_PASSWORD=change_me
MYSQL_SYNTHETIC_DATABASE=esf_synthetic_demo
# Эталон структуры (тот же инстанс MySQL): CREATE TABLE … LIKE при отсутствии таблиц
MYSQL_SYNTHETIC_SCHEMA_SOURCE=esf-ver
# 1 — load_edges / compute_state читают из синтетической БД
MYSQL_USE_SYNTHETIC=0
# rolling — последние N дней (N = параметр recompute); calendar — ESF_SYNTHETIC_YEAR
ESF_SYNTHETIC_WINDOW=rolling
ESF_SYNTHETIC_YEAR=2025

# =====================================================
# VoltDB — справочники резидентов / нерезидентов / профилей
# =====================================================
# Стандартный клиентский порт VoltDB: 21212
# Несколько хостов через запятую. Backend в Docker: лучше IP хоста в VPN (не host.docker.internal на Linux).
VOLTDB_HOSTS=127.0.0.1
VOLTDB_PORT=21212
VOLTDB_USER=
VOLTDB_PASSWORD=

# =====================================================
# Доступ к веб-интерфейсу (инвайты + OTP админов, Resend)
# =====================================================
ENABLE_ACCESS_GATE=1
# Секрет подписи JWT (>= 16 символов), сгенерируйте: openssl rand -hex 32
AUTH_JWT_SECRET=
# Resend: https://resend.com — НЕ коммить реальный ключ
RESEND_API_KEY=
# Адрес «От кого». Варианты:
# - onboarding@resend.dev — только тест: письма УХОДЯТ ТОЛЬКО на email владельца аккаунта Resend.
#   Инвайт гостю с другим адресом вернёт ошибку (нужен свой домен).
# После верификации домена в Resend ОБЯЗАТЕЛЬНО смените на адрес с ЭТОГО домена, иначе останетесь в тестовом режиме:
# RESEND_FROM=noreply@your-verified-domain.com
RESEND_FROM=onboarding@resend.dev
# Админы (через запятую)
ADMIN_EMAILS=okostrikin@gmail.com,anvar.sadykov@gmail.com
# SQLite для кодов: для `docker compose` путь задаётся в docker-compose.yml (/app/data/auth.sqlite)
# и перекрывает эту строку из .env. Для локального uv без Docker укажите путь на хосте:
AUTH_SQLITE_PATH=./services/backend/data/auth.sqlite
# Опционально: 1 для HTTPS-only cookie
# AUTH_COOKIE_SECURE=0
